FROM node:20-bullseye AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-bullseye AS builder
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY
ARG NEXT_PUBLIC_LEGAL_COMPANY_NAME
ARG NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT
ARG NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS
ARG NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL
ARG NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL
ARG NEXT_PUBLIC_LEGAL_CONTACT_EMAIL
ARG NEXT_PUBLIC_LEGAL_DPO_NAME
ARG NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE
ARG NEXT_PUBLIC_BUILD_ID
ARG RAILWAY_DEPLOYMENT_ID
ARG RAILWAY_GIT_COMMIT_SHA
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY
ENV NEXT_PUBLIC_LEGAL_COMPANY_NAME=$NEXT_PUBLIC_LEGAL_COMPANY_NAME
ENV NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT=$NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT
ENV NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS=$NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS
ENV NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL=$NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL
ENV NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL=$NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL
ENV NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=$NEXT_PUBLIC_LEGAL_CONTACT_EMAIL
ENV NEXT_PUBLIC_LEGAL_DPO_NAME=$NEXT_PUBLIC_LEGAL_DPO_NAME
ENV NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE=$NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE
ENV NEXT_PUBLIC_BUILD_ID=$NEXT_PUBLIC_BUILD_ID
ENV RAILWAY_DEPLOYMENT_ID=$RAILWAY_DEPLOYMENT_ID
ENV RAILWAY_GIT_COMMIT_SHA=$RAILWAY_GIT_COMMIT_SHA
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-bullseye-slim AS runner
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY
ARG NEXT_PUBLIC_LEGAL_COMPANY_NAME
ARG NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT
ARG NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS
ARG NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL
ARG NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL
ARG NEXT_PUBLIC_LEGAL_CONTACT_EMAIL
ARG NEXT_PUBLIC_LEGAL_DPO_NAME
ARG NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY
ENV NEXT_PUBLIC_LEGAL_COMPANY_NAME=$NEXT_PUBLIC_LEGAL_COMPANY_NAME
ENV NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT=$NEXT_PUBLIC_LEGAL_COMPANY_DOCUMENT
ENV NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS=$NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS
ENV NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL=$NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL
ENV NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL=$NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL
ENV NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=$NEXT_PUBLIC_LEGAL_CONTACT_EMAIL
ENV NEXT_PUBLIC_LEGAL_DPO_NAME=$NEXT_PUBLIC_LEGAL_DPO_NAME
ENV NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE=$NEXT_PUBLIC_LEGAL_FORUM_CITY_STATE
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/next.config.mjs ./next.config.mjs
COPY --from=builder /app/scripts ./scripts
EXPOSE 3000
CMD ["npm", "run", "start"]
