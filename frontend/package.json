    "lint:styles": "stylelint \"**/*.{css,scss}\"",
    "test": "node scripts/run-jest.cjs --config jest.config.cjs --runInBand --no-cache",
    "test:ci": "node scripts/run-jest.cjs --ci --runInBand --config jest.config.cjs --no-cache"
