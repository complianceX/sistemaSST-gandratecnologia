# ---------------------------------
# Core Application Configuration
# ---------------------------------
# Environment: 'development', 'production', or 'test'
NODE_ENV=development
# Port to run the application on
PORT=3001

# ---------------------------------
# Security & JWT Configuration
# ---------------------------------
# CRITICAL: Must be at least 32 characters long for production
JWT_SECRET=CHANGE_THIS_TO_A_32_CHAR_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_32_CHAR_SECRET

# Hardening opcional: vincular refresh token ao User-Agent
# Valores: none | ua
REFRESH_BINDING=none

# ---------------------------------
# Database (PostgreSQL) Configuration
# ---------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=minha-api
# Optional: For production environments that require SSL/TLS connection to the database
# Provide the CA certificate content as a Base64 encoded string.
# SECURITY: CA certificate do provedor (Railway/RDS) para validar SSL do banco
DATABASE_SSL=false
DATABASE_SSL_ALLOW_INSECURE=false
DATABASE_SSL_CA=

# ---------------------------------
# Cache & Queue (Redis) Configuration
# ---------------------------------
# Option 1: Provide a REDIS_URL (takes precedence)
REDIS_URL=
# Option 2: Provide individual host, port, and password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------
# Bull Board (filas) — Hardening
# ---------------------------------
# Para habilitar /admin/queues, configure uma senha (Basic Auth).
# Observação: a rota só aceita acesso via localhost.
BULL_BOARD_USER=admin
BULL_BOARD_PASS=

# ---------------------------------
# S3-Compatible Storage Configuration
# ---------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=auto
AWS_ENDPOINT=
# Set to 'true' if using a local S3-compatible service like MinIO
S3_FORCE_PATH_STYLE=false

# ---------------------------------
# Other Services
# ---------------------------------
# ---------------------------------
# AI (SOPHIE) — OpenAI (recomendado)
# ---------------------------------
# Feature flag: desativa completamente endpoints de IA (/ai/* e /sophie/*).
# Valores: true | false
FEATURE_AI_ENABLED=false

# Provedor principal da SOPHIE:
# Valores: openai | anthropic | gemini | stub | local
AI_PROVIDER=openai

OPENAI_API_KEY=
# Modelo para chat (tool calling)
OPENAI_MODEL=
# Modelo para análise de imagem (vision). Se vazio, usa OPENAI_MODEL.
OPENAI_VISION_MODEL=

# SMTP (prioridade): se MAIL_HOST/MAIL_USER/MAIL_PASS estiverem preenchidos,
# o envio usa SMTP (ex.: Brevo). Caso contrário, usa Resend.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

RESEND_API_KEY=
MAIL_FROM_NAME="GST - Gestão de Segurança do Trabalho"
MAIL_FROM_EMAIL=onboarding@resend.dev

# Agendamento de alertas automáticos por e-mail
MAIL_ALERT_SCHEDULE_MIN_INTERVAL_MS=300000
MAIL_ALERT_COMPANY_BATCH_SIZE=10
MAIL_ALERT_COMPANY_MAX_PARALLEL=2

# ---------------------------------
# PgBouncer (produção)
# ---------------------------------
# SECURITY: transaction pooling para apps stateless (NestJS)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Dica: ao usar PgBouncer, a API deve apontar para o PgBouncer:
# DATABASE_URL=postgresql://postgres:postgres@${PGBOUNCER_HOST}:${PGBOUNCER_PORT}/${DATABASE_NAME}
# Em Railway: use o endpoint de PgBouncer fornecido pelo provedor (porta 5432)
# SECURITY: prepared statements não funcionam com POOL_MODE=transaction
# Compatibilidade já habilitada via app.module.ts (extra.prepareThreshold=0)

# ---------------------------------
# DEV LOGIN BYPASS (somente desenvolvimento)
# ---------------------------------
# Quando DEV_LOGIN_BYPASS=true, permite login sem DB (credenciais abaixo).
# Use apenas para destravar UI quando o banco estiver indisponível.
DEV_ADMIN_CPF=15082302698
DEV_ADMIN_PASSWORD=GANDRA@2026
DEV_LOGIN_BYPASS=false

# Desabilita throttle de login em DEV de forma explícita (não use em ambientes expostos)
DISABLE_LOGIN_THROTTLE_IN_DEV=false

# Proteção anti brute force (por IP) no endpoint /auth/login
LOGIN_FAIL_MAX=10
LOGIN_FAIL_WINDOW_SECONDS=900
LOGIN_FAIL_BLOCK_SECONDS=900

# Multi-tenant hardening:
# Quando true, ADMIN_GERAL só acessa rotas tenant-scoped se enviar `x-company-id`.
# Rotas globais devem ser anotadas com @TenantOptional().
REQUIRE_EXPLICIT_TENANT_FOR_SUPER_ADMIN=false
