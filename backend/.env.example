# ---------------------------------
# Core Application Configuration
# ---------------------------------
# Environment: 'development', 'production', or 'test'
NODE_ENV=development
# Port to run the application on
PORT=3001

# Thread pool do libuv — DEVE ser definido no ambiente do processo antes de iniciar Node.
# Aumentar evita fila de bcrypt/argon2 sob carga concorrente.
# Em instâncias pequenas, valores muito altos podem aumentar uso de memória.
# Recomendado inicial: 16 (suba gradualmente conforme CPU/RAM disponível).
UV_THREADPOOL_SIZE=16

# ---------------------------------
# Security & JWT Configuration
# ---------------------------------
# CRITICAL: Must be at least 32 characters long for production
JWT_SECRET=CHANGE_THIS_TO_A_32_CHAR_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_32_CHAR_SECRET
ACCESS_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_DAYS=30
# Variáveis legadas ainda aceitas para compatibilidade:
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRATION=30d

# Hardening opcional: vincular refresh token ao User-Agent
# Valores: none | ua
REFRESH_BINDING=none

# Argon2 tuning (segurança x capacidade)
# Defaults atuais equilibram segurança com estabilidade sob concorrência.
# Para endurecer em instâncias maiores, aumente gradualmente MEMORY/TIME.
PASSWORD_ARGON2_MEMORY_COST_KIB=19456
PASSWORD_ARGON2_TIME_COST=2
PASSWORD_ARGON2_PARALLELISM=1
# Limite global de concorrência para hash/verify de senha.
# Evita pico de memória e kill do processo sob rajadas de login.
PASSWORD_HASH_MAX_CONCURRENCY=8
# Ajustes finos (opcional): separar concorrência de escrita (hash) e leitura (verify).
# Em picos de login, aumentar VERIFY ajuda a reduzir fila sem elevar custo de rotas de escrita.
PASSWORD_HASH_WRITE_MAX_CONCURRENCY=8
PASSWORD_VERIFY_MAX_CONCURRENCY=8

# ---------------------------------
# Database (PostgreSQL) Configuration
# ---------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=minha-api
# Optional: For production environments that require SSL/TLS connection to the database
# Provide the CA certificate content as a Base64 encoded string.
# SECURITY: CA certificate do provedor (Railway/RDS) para validar SSL do banco
DATABASE_SSL=false
DATABASE_SSL_ALLOW_INSECURE=false
DATABASE_SSL_CA=
# Identificação de origem no Postgres (aparece em pg_stat_activity)
DB_APPLICATION_NAME_WEB=api_web
DB_APPLICATION_NAME_WORKER=api_worker
DB_APPLICATION_NAME=

# ---------------------------------
# Cache & Queue (Redis) Configuration
# ---------------------------------
# Option 1: Provide a REDIS_URL (takes precedence)
REDIS_URL=
# Option 2: Provide individual host, port, and password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis hardening / emergency mode
# - REDIS_DISABLED=true: modo degradado (não recomendado para produção)
# - REDIS_FAIL_OPEN=true: permite fallback em memória quando Redis não conecta (apenas dev por padrão)
# - REDIS_ALLOW_IN_MEMORY_FALLBACK_IN_PROD=true: libera explicitamente fallback em produção (modo emergencial)
REDIS_DISABLED=false
REDIS_FAIL_OPEN=false
REDIS_ALLOW_IN_MEMORY_FALLBACK_IN_PROD=false

# ---------------------------------
# Bull Board (filas) — Hardening
# ---------------------------------
# Para habilitar /admin/queues, configure uma senha (Basic Auth).
# Observação: a rota só aceita acesso via localhost.
BULL_BOARD_USER=admin
BULL_BOARD_PASS=

# ---------------------------------
# S3-Compatible Storage Configuration
# ---------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=auto
AWS_ENDPOINT=
# Set to 'true' if using a local S3-compatible service like MinIO
S3_FORCE_PATH_STYLE=false

# ---------------------------------
# Secondary Replica Storage (DR)
# ---------------------------------
DR_STORAGE_REPLICA_BUCKET=
DR_STORAGE_REPLICA_ENDPOINT=
DR_STORAGE_REPLICA_REGION=auto
DR_STORAGE_REPLICA_ACCESS_KEY_ID=
DR_STORAGE_REPLICA_SECRET_ACCESS_KEY=
DR_STORAGE_REPLICA_FORCE_PATH_STYLE=true

# ---------------------------------
# Other Services
# ---------------------------------
# ---------------------------------
# AI (SOPHIE) — OpenAI (recomendado)
# ---------------------------------
# Feature flag: desativa completamente endpoints de IA (/ai/* e /sophie/*).
# Valores: true | false
FEATURE_AI_ENABLED=true

# Provedor oficial da SOPHIE:
# Valores suportados neste produto: openai | stub | local
AI_PROVIDER=openai

OPENAI_API_KEY=
# Modelo para chat (tool calling)
OPENAI_MODEL=gpt-4.1-mini
# Modelo para análise de imagem (vision). Se vazio, usa OPENAI_MODEL.
OPENAI_VISION_MODEL=gpt-4.1-mini

# SMTP (prioridade): se MAIL_HOST/MAIL_USER/MAIL_PASS estiverem preenchidos,
# o envio usa SMTP (ex.: Brevo). Caso contrário, usa Resend.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

RESEND_API_KEY=
MAIL_FROM_NAME="GST - Gestão de Segurança do Trabalho"
MAIL_FROM_EMAIL=onboarding@resend.dev
MAIL_REPLY_TO_NAME="GST - Gestão de Segurança do Trabalho"
MAIL_REPLY_TO_EMAIL=suporte@seudominio.com

# Agendamento de alertas automáticos por e-mail
MAIL_ALERT_SCHEDULE_MIN_INTERVAL_MS=300000
MAIL_ALERT_SCHEDULE_LOCK_TTL_MS=600000
MAIL_ALERT_COMPANY_BATCH_SIZE=10
MAIL_ALERT_COMPANY_MAX_PARALLEL=2

# Heartbeat do processo worker (para /health detectar fila viva)
WORKER_HEARTBEAT_ENABLED=true
WORKER_HEARTBEAT_REQUIRED=false
WORKER_HEARTBEAT_KEY=worker:heartbeat:queue-runtime
WORKER_HEARTBEAT_TTL_SECONDS=90

# ---------------------------------
# Observabilidade (opcional)
# ---------------------------------
LOG_LEVEL=debug
OTEL_ENABLED=false
OTEL_SERVICE_NAME=wanderson-gandra-backend
OTEL_SERVICE_VERSION=1.0.0
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9464
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_TIMEOUT_MS=5000
NEW_RELIC_ENABLED=false
PERF_PROFILING_ENABLED=false
PERF_PROFILING_SAMPLE_RATE=0.2
# Obrigatório quando NEW_RELIC_ENABLED=true (obtenha em one.newrelic.com → API keys)
NEW_RELIC_LICENSE_KEY=
# Nome exibido no painel New Relic (sobrescreve app_name em newrelic.js)
NEW_RELIC_APP_NAME=wanderson-gandra-backend

# ---------------------------------
# PgBouncer (produção)
# ---------------------------------
# SECURITY: transaction pooling para apps stateless (NestJS)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Dica: ao usar PgBouncer, a API deve apontar para o PgBouncer:
# DATABASE_URL=postgresql://postgres:postgres@${PGBOUNCER_HOST}:${PGBOUNCER_PORT}/${DATABASE_NAME}
# Em Railway: use o endpoint de PgBouncer fornecido pelo provedor (porta 5432)
# SECURITY: prepared statements não funcionam com POOL_MODE=transaction
# Compatibilidade já habilitada via app.module.ts (extra.prepareThreshold=0)

# ---------------------------------
# DEV LOGIN BYPASS (somente desenvolvimento)
# ---------------------------------
# Quando DEV_LOGIN_BYPASS=true, permite login sem DB (credenciais abaixo).
# Use apenas para destravar UI quando o banco estiver indisponível.
DEV_ADMIN_CPF=15082302698
DEV_ADMIN_PASSWORD=change-me-dev-only
DEV_LOGIN_BYPASS=false

# Desabilita throttle de login em DEV de forma explícita (não use em ambientes expostos)
DISABLE_LOGIN_THROTTLE_IN_DEV=false

# Proteção anti brute force (por IP) no endpoint /auth/login
LOGIN_FAIL_MAX=10
LOGIN_FAIL_WINDOW_SECONDS=900
LOGIN_FAIL_BLOCK_SECONDS=900

# Multi-tenant hardening:
# Quando true, ADMIN_GERAL só acessa rotas tenant-scoped se enviar `x-company-id`.
# Rotas globais devem ser anotadas com @TenantOptional().
REQUIRE_EXPLICIT_TENANT_FOR_SUPER_ADMIN=false

# ---------------------------------
# Public validation hardening (faseado)
# ---------------------------------
# Segredo para assinar token opaco de validação pública de documentos.
VALIDATION_TOKEN_SECRET=CHANGE_THIS_TO_A_DIFFERENT_32_CHAR_SECRET
# Compatibilidade temporária com contrato legado (code-only). Desativar após migração.
PUBLIC_VALIDATION_LEGACY_COMPAT=false
PUBLIC_VALIDATION_LOG_CONTRACT_USAGE=true

# ---------------------------------
# Refresh hardening (CSRF + rate limit)
# ---------------------------------
REFRESH_THROTTLE_LIMIT=20
REFRESH_THROTTLE_TTL=60000
# Modo de rollout:
# 1) REFRESH_CSRF_REPORT_ONLY=true / REFRESH_CSRF_ENFORCED=false
# 2) após frontend enviar x-refresh-csrf, ativar REFRESH_CSRF_ENFORCED=true
REFRESH_CSRF_REPORT_ONLY=true
REFRESH_CSRF_ENFORCED=true

# Quando true, se o throttler Redis falhar em /auth/login, /auth/refresh ou /auth/me,
# o backend responde erro (fail-closed) em vez de liberar requisição.
THROTTLER_FAIL_CLOSED_AUTH_ROUTES=true
# Em falha/timeout do storage Redis do throttler:
# - true  => fail-open (continua sem bloquear)
# - false => propaga erro para o guard decidir fallback/503.
# Recomendado em produção: false (mais previsível e auditável).
THROTTLER_STORAGE_FAIL_OPEN=false
# Timeout dedicado para o storage Redis do throttler (ms).
# Evita pendurar request no Redis em cenários de instabilidade.
THROTTLER_STORAGE_REDIS_TIMEOUT_MS=200
# Fallback local para autenticação quando o throttler Redis está indisponível.
# Mantém proteção básica sem transformar indisponibilidade de Redis em 503 em massa.
THROTTLER_AUTH_LOCAL_FALLBACK_ENABLED=true
THROTTLER_AUTH_LOCAL_FALLBACK_LIMIT=60
THROTTLER_AUTH_LOCAL_FALLBACK_TTL_MS=60000
# /auth/me recebe limite próprio no fallback local para não estrangular o fluxo
# de sessão em cenários de oscilação temporária do Redis.
THROTTLER_AUTH_ME_LOCAL_FALLBACK_LIMIT=1200
THROTTLER_AUTH_ME_LOCAL_FALLBACK_TTL_MS=60000
# Timeout máximo para decisão do throttler Redis antes de cair no fallback local.
THROTTLER_DECISION_TIMEOUT_MS=250
# Cooldown de log para evitar spam quando fallback está ativo sob carga (ms).
THROTTLER_AUTH_FALLBACK_LOG_COOLDOWN_MS=15000

# Observabilidade de rollout
SECURITY_HARDENING_PHASE=phase0

# ---------------------------------
# Auth performance (cache curto)
# ---------------------------------
RBAC_ACCESS_CACHE_TTL_SECONDS=120
AUTH_SESSION_USER_CACHE_TTL_SECONDS=45
AUTH_PROFILE_NAME_CACHE_TTL_SECONDS=300
# Limite de sessões refresh ativas por usuário.
# Valor maior reduz churn/evictions em cenários de múltiplos logins concorrentes.
MAX_ACTIVE_SESSIONS_PER_USER=10

# ---------------------------------
# Rate Limiting (Resilient Throttler) — PR #4
# ---------------------------------
# Ativar/desativar sistema inteiro de rate limiting
THROTTLER_ENABLED=true
# Falhar fechado em rotas críticas quando Redis offline
THROTTLER_FAIL_CLOSED=true

# Limites por tipo de rota (requisições / minuto)
THROTTLER_AUTH_LIMIT=5              # POST /auth/login
THROTTLER_PUBLIC_LIMIT=10            # /validate, /public/* routes
THROTTLER_API_LIMIT=100              # /api/* routes
THROTTLER_DASHBOARD_LIMIT=50         # /dashboard/* routes

# Comprimento da janela de limite (em ms)
THROTTLER_WINDOW_MS=60000            # 60 segundos

# ---------------------------------
# CSRF Protection — PR #5
# ---------------------------------
# Ativar proteção CSRF
REFRESH_CSRF_ENFORCED=true
# Modo report-only (log violations sem bloquear)
REFRESH_CSRF_REPORT_ONLY=false
# Segredo para assinar tokens CSRF (mínimo 32 caracteres)
CSRF_TOKEN_SECRET=CHANGE_THIS_TO_A_DIFFERENT_32_CHAR_SECRET
# TTL do token CSRF em segundos
CSRF_TOKEN_TTL_SECONDS=3600

# ---------------------------------
# Dashboard Cache — PR #6
# ---------------------------------
# Ativar/desativar cache de dashboard
DASHBOARD_CACHE_ENABLED=true

# TTL para diferentes tipos de cache (em segundos)
DASHBOARD_CACHE_TTL_METRICS=300       # 5 minutos (dashboard KPIs)
DASHBOARD_CACHE_TTL_ACTIVITIES=60     # 1 minuto (activity feed)
DASHBOARD_CACHE_TTL_SUMMARIES=3600    # 1 hora (résumés mensais)

# ---------------------------------
# N+1 Query Detection — PR #7 (Dev tool)
# ---------------------------------
# Ativar detecção de padrões N+1 (apenas desenvolvimento)
N1_QUERY_DETECTION_ENABLED=false
# Limiar de repetições para alertar sobre N+1
N1_QUERY_THRESHOLD=3
# Limiar de latência para reportar queries lentas (ms)
N1_SLOW_QUERY_THRESHOLD=100
