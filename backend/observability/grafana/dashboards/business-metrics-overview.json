{
  "dashboard": {
    "title": "GST - Business Metrics Overview",
    "tags": ["gst", "business-metrics", "multi-tenant"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Atividade Geral (criações por dia)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(increase(gst_aprs_created_total[1d]))",
            "legendFormat": "APRs/dia"
          },
          {
            "expr": "sum(increase(gst_dds_created_total[1d]))",
            "legendFormat": "DDS/dia"
          },
          {
            "expr": "sum(increase(gst_pts_created_total[1d]))",
            "legendFormat": "PTs/dia"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Compliance (vencidos por tenant)",
        "type": "graph",
        "targets": [
          {
            "expr": "gst_exams_overdue_count + on(company_id) gst_trainings_overdue_count",
            "legendFormat": "{{company_id}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Uso de IA (Sophie)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(increase(gst_ai_interactions_total[1d]))",
            "legendFormat": "Interações/dia"
          },
          {
            "expr": "sum(increase(gst_ai_tokens_used_total[1d]))",
            "legendFormat": "Tokens/dia"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(gst_ai_response_time_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95 resposta (s)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Top Tenants por Atividade (7d)",
        "type": "graph",
        "targets": [
          {
            "expr": "topk(10, sum by (company_id) (increase(gst_aprs_created_total[7d])) + sum by (company_id) (increase(gst_dds_created_total[7d])) + sum by (company_id) (increase(gst_pts_created_total[7d])))",
            "legendFormat": "{{company_id}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      }
    ]
  }
}

