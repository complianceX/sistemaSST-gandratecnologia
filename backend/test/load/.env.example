# Base target URL (supports local or Railway). Include API prefix if your ingress uses one.
# Examples:
# BASE_URL=http://localhost:3001
# BASE_URL=http://localhost:3001/api/v1
# BASE_URL=https://your-api.up.railway.app
BASE_URL=http://localhost:3001

# Real login credentials used by k6.
# CPF must have 11 digits (dots/hyphen are accepted and normalized by script).
LOGIN_CPF=00000000000
LOGIN_PASSWORD=change-me

# Optional: if your target requires explicit tenant header on /auth/me.
LOGIN_COMPANY_ID=

# Optional: if Turnstile is enabled in target env.
TURNSTILE_TOKEN=

# Optional: list of credentials to avoid lockout/rate-limit artifacts.
# File format: [{"cpf":"00000000000","password":"...","companyId":"...","fingerprint":"...","turnstileToken":"..."}]
LOGIN_USERS_FILE=test/load/fixtures/login-users.120.json
CREDENTIAL_FILTER_COMPANY_ID=
CREDENTIAL_FILTER_COMPANY_NAME=
CREDENTIAL_FILTER_PROFILE=
MIN_CREDENTIAL_POOL_SIZE=120
REQUIRE_MIN_CREDENTIAL_POOL=true

# Endpoint paths (keep defaults unless your gateway rewrites paths)
LOGIN_PATH=/auth/login
AUTH_ME_PATH=/auth/me
CALL_AUTH_ME=true
LOGIN_OK_STATUS=200,201
AUTH_ME_OK_STATUS=200

# Fingerprint mode: per-vu | per-iteration | static | none
CLIENT_FINGERPRINT_MODE=per-vu
CLIENT_FINGERPRINT=

# Progressive load stages (login-load.js)
STAGE_10_DURATION=2m
STAGE_25_DURATION=3m
STAGE_50_DURATION=3m
STAGE_75_DURATION=3m
STAGE_100_DURATION=3m
STAGE_150_DURATION=3m
STAGE_200_DURATION=3m
COOLDOWN_DURATION=2m
PREALLOCATED_VUS=320
MAX_VUS=1500
ENABLE_SATURATION_HOLD=true
HOLD_RATE=200
HOLD_DURATION=10m
HOLD_START_TIME=22m
DROPPED_ITERATIONS_MAX=5000

# Soak (login-soak.js)
SOAK_RATE=75
SOAK_DURATION=60m
SOAK_PREALLOCATED_VUS=250
SOAK_MAX_VUS=1200
SOAK_DROPPED_ITERATIONS_MAX=2000

# Import de usuarios para login (opcional)
IMPORT_USERS_FILE=test/load/fixtures/users-batch-2026-03-28.csv
IMPORT_USERS_OUTPUT_FILE=test/load/fixtures/login-users.generated.json
IMPORT_USERS_DEFAULT_PASSWORD=Teste@123
IMPORT_USERS_AUTOFIX_INVALID_CPF=true
