{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testTimeout": 30000,
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/uuid-cjs.js"
  },
  "globalSetup": "<rootDir>/setup/e2e-infra-check.ts",
  "maxWorkers": 1,
  "workerThreads": false
}
