# ============================================
# 🔒 CONFIGURAÇÃO DE PRODUÇÃO - SEGURANÇA MÁXIMA
# ============================================

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=production
PORT=3000

# Origem(ns) explícita(s) do frontend autorizadas a consumir esta API.
# Separe múltiplas origens por vírgula e mantenha alinhado com NEXT_PUBLIC_APP_URL do frontend.
CORS_ALLOWED_ORIGINS=https://app.seu-dominio.com

# Compartilha cookies de sessão/CSRF entre subdomínios (frontend + API).
# Exemplo: .sgsseguranca.com.br
AUTH_COOKIE_DOMAIN=.seu-dominio.com

# ============================================
# BANCO DE DADOS - POSTGRESQL
# ============================================
# Opcao 1: DATABASE_URL (Supabase/Render recomendado para este projeto)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Exemplo Supabase (session pooler 5432, recomendado para NestJS/TypeORM):
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
# Observacao: para backend stateful (Nest + TypeORM), prefira pooler de sessao (5432).
# Evite pooler de transacao (6543) no V1 para reduzir risco operacional.

# Opção 2: Variáveis individuais
# DATABASE_HOST=your-db-host.com
# DATABASE_PORT=5432
# DATABASE_USER=your_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=your_database

# Pool por instância (evita exaustão de conexão sob carga/escala horizontal)
# Ajuste junto com o plano do Postgres e o número de réplicas do WEB/WORKER.
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
# Identificação de origem no Postgres (pg_stat_activity / pg_stat_statements).
DB_APPLICATION_NAME_WEB=api_web
DB_APPLICATION_NAME_WORKER=api_worker
DB_APPLICATION_NAME=

# Timeouts reais no Postgres (aplicados por sessão a cada acquire do pool)
# WEB (recomendado): mais estrito para proteger p95/p99 e evitar queries penduradas.
# WORKER: pode ser maior (configurar variáveis diferentes por serviço no Railway).
PG_STATEMENT_TIMEOUT_MS=25000
PG_LOCK_TIMEOUT_MS=2000
PG_IDLE_IN_TX_TIMEOUT_MS=15000

# Migrations (proteção contra concorrência web/worker)
MIGRATION_ADVISORY_LOCK_TIMEOUT_MS=300000

# 🔒 SSL OBRIGATÓRIO EM PRODUÇÃO
DATABASE_SSL=true
# ⚠️ Somente em último caso (self-signed interno): true
DATABASE_SSL_ALLOW_INSECURE=false

# 🔒 Certificado CA customizado (opcional)
# Para AWS RDS, Railway, Heroku: não é necessário
# Para servidores customizados: forneça o certificado CA
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\nMIID....\n-----END CERTIFICATE-----

# ============================================
# REDIS - OBRIGATÓRIO EM PRODUÇÃO
# ============================================
# Opção 1: REDIS_URL (Render Key Value, Upstash, etc)
REDIS_URL=redis://user:password@host:6379

# Opção 2: Variáveis individuais
# REDIS_HOST=your-redis-host.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_TLS=true

# Redis hardening (produção)
# - REDIS_DISABLED=true não é recomendado (e é bloqueado por padrão no runtime web/worker).
# - REDIS_FAIL_OPEN=true é ignorado em produção, a menos que você libere modo emergencial.
REDIS_DISABLED=false
REDIS_FAIL_OPEN=false
REDIS_ALLOW_IN_MEMORY_FALLBACK_IN_PROD=false

# ============================================
# BULLMQ / DLQ (retenção)
# ============================================
# Evita crescimento infinito no Redis quando DLQ acumula (DLQ não é consumida).
DLQ_MAX_WAITING=2000
DLQ_PRUNE_BATCH=200
# Overrides por fila (opcional):
# DLQ_PDF_GENERATION_DLQ_MAX_WAITING=2000
# DLQ_MAIL_DLQ_MAX_WAITING=2000
# DLQ_DOCUMENT_IMPORT_DLQ_MAX_WAITING=2000

# Proteção do endpoint /reports/jobs (scan limitado para evitar Redis meltdown)
REPORTS_QUEUE_SCAN_MAX_PER_STATE=200

# Clamp global de paginação (protege Postgres de ?limit abusivo)
PAGINATION_LIMIT_MAX=100
PAGINATION_PAGE_MAX=10000

# ============================================
# JWT - SEGURANÇA
# ============================================
# ⚠️  MÍNIMO 32 CARACTERES - GERE COM: openssl rand -base64 32
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_here_change_this
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_min_32_chars_here_change_this
VALIDATION_TOKEN_SECRET=your_super_secure_validation_secret_min_32_chars_here_change_this
# Preferencial (novo): ACCESS_TOKEN_TTL; compatível com JWT_EXPIRES_IN (legado)
ACCESS_TOKEN_TTL=7d
JWT_EXPIRES_IN=7d
# Preferencial (novo): REFRESH_TOKEN_TTL_DAYS; compatível com JWT_REFRESH_EXPIRATION (legado)
REFRESH_TOKEN_TTL_DAYS=30
JWT_REFRESH_EXPIRATION=30d

# Contrato público de validação (migração)
# Em produção final: false
PUBLIC_VALIDATION_LEGACY_COMPAT=false
PUBLIC_VALIDATION_LOG_CONTRACT_USAGE=true

# ============================================
# EMAIL - SMTP
# ============================================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_user
MAIL_PASS=your_smtp_password
MAIL_FROM_EMAIL=noreply@yourdomain.com
MAIL_FROM_NAME=Your Company Name
MAIL_REPLY_TO_EMAIL=support@yourdomain.com
MAIL_REPLY_TO_NAME=Your Company Name
MAIL_ALERT_SCHEDULE_MIN_INTERVAL_MS=300000
MAIL_ALERT_SCHEDULE_LOCK_TTL_MS=600000
WORKER_HEARTBEAT_ENABLED=true
WORKER_HEARTBEAT_REQUIRED=true
WORKER_HEARTBEAT_KEY=worker:heartbeat:queue-runtime
WORKER_HEARTBEAT_TTL_SECONDS=90

# ============================================
# AWS S3 / CLOUDFLARE R2
# ============================================
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Para Cloudflare R2:
# AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Upload do PDF governado (bytes). Ajuste conforme perfil dos documentos.
# Exemplo: 52428800 = 50MB.
GOVERNED_PDF_MAX_FILE_SIZE_BYTES=52428800

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
REFRESH_THROTTLE_LIMIT=5
REFRESH_THROTTLE_TTL=60000
REFRESH_CSRF_REPORT_ONLY=true
REFRESH_CSRF_ENFORCED=true
SECURITY_HARDENING_PHASE=phase0

# Throttler Redis storage hardening (produção)
THROTTLER_FAIL_CLOSED_AUTH_ROUTES=true
THROTTLER_STORAGE_FAIL_OPEN=false
THROTTLER_STORAGE_REDIS_TIMEOUT_MS=200
THROTTLER_DECISION_TIMEOUT_MS=250
THROTTLER_AUTH_LOCAL_FALLBACK_ENABLED=true
THROTTLER_AUTH_LOCAL_FALLBACK_LIMIT=60
THROTTLER_AUTH_LOCAL_FALLBACK_TTL_MS=60000
THROTTLER_AUTH_ME_LOCAL_FALLBACK_LIMIT=1200
THROTTLER_AUTH_ME_LOCAL_FALLBACK_TTL_MS=60000
THROTTLER_AUTH_FALLBACK_LOG_COOLDOWN_MS=15000

# Timeout global do HTTP (não substitui timeouts do Postgres)
REQUEST_TIMEOUT_MS=30000

# ============================================
# OBSERVABILIDADE (OPCIONAL)
# ============================================
LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_SERVICE_NAME=wanderson-gandra-backend
OTEL_SERVICE_VERSION=1.0.0
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9464
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEW_RELIC_ENABLED=false
PERF_PROFILING_ENABLED=false
PERF_PROFILING_SAMPLE_RATE=0.2

# ============================================
# AI - SOPHIE / OPENAI (OPCIONAL)
# ============================================
# Feature flag global de IA
FEATURE_AI_ENABLED=true

# Provider oficial exposto neste produto: openai | stub
AI_PROVIDER=openai

# Configure a chave real apenas no ambiente/serviço (ex.: Railway Variables)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
AI_HISTORY_DEFAULT_DAYS=30
AI_HISTORY_MAX_DAYS=90
AI_HISTORY_MAX_LIMIT=100

# ============================================
# NOTAS DE SEGURANÇA
# ============================================
# 1. NUNCA commite este arquivo com valores reais
# 2. Use secrets manager em produção (AWS Secrets Manager, Railway Secrets, etc)
# 3. Rotacione credenciais regularmente
# 4. Use senhas fortes (mínimo 16 caracteres)
# 5. Habilite 2FA em todos os serviços
# 6. Monitore logs de acesso
# 7. Configure alertas de segurança
