    "db:security-posture:strict": "node scripts/database-security-posture-check.js --json --strict",
    "db:prod-repair:preflight": "node scripts/prod-data-repair-preflight.js",
    "db:prod-repair:preflight:json": "node scripts/prod-data-repair-preflight.js --json",
    "db:null-password:review": "node scripts/prod-null-password-users-review.js",
    "db:null-password:review:json": "node scripts/prod-null-password-users-review.js --json",
