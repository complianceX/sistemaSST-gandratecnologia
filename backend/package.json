    "signatures:externalize:apply": "node scripts/externalize-signature-data.js --apply",
    "signatures:externalize:verify": "node scripts/externalize-signature-data.js --verify-only",
    "companies:logos:externalize:dry": "node scripts/externalize-company-logos.js",
    "companies:logos:externalize:apply": "node scripts/externalize-company-logos.js --apply",
    "companies:logos:externalize:verify": "node scripts/externalize-company-logos.js --verify-only",
