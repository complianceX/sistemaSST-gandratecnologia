    "loadtest:login:progressive": "k6 run test/load/login-load.js",
    "loadtest:login:soak": "k6 run test/load/login-soak.js",
    "loadtest:battery:smoke": "node scripts/run-load-battery.cjs --mode smoke",
    "loadtest:battery:baseline": "node scripts/run-load-battery.cjs --mode baseline",
    "loadtest:battery:stress": "node scripts/run-load-battery.cjs --mode stress",
    "loadtest:battery:full": "node scripts/run-load-battery.cjs --mode full",
    "loadtest:auth:users:build": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register test/load/build-auth-me-users.ts",
    "loadtest:dds:users:build": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register test/load/build-dds-publish-users.ts",
    "loadtest:dds:smoke": "k6 run ../test/load/k6-dds-emission.js -e TEST_PROFILE=smoke",
    "loadtest:dds:progressive": "k6 run ../test/load/k6-dds-emission.js -e TEST_PROFILE=progressive",
    "loadtest:dds:soak": "k6 run ../test/load/k6-dds-emission.js -e TEST_PROFILE=soak60",
    "loadtest:users:import": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register test/load/import-login-users.ts",
    "loadtest:users:import:dry": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register test/load/import-login-users.ts --dry-run",
    "recovery:ajn-quality": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-ajn-quality-from-csv.ts --apply",
    "recovery:ajn-quality:dry": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-ajn-quality-from-csv.ts --dry-run",
    "recovery:null-password": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-null-password-users.ts --apply",
    "recovery:null-password:dry": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-null-password-users.ts",
    "recovery:rbac": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-rbac-production.ts --apply",
    "recovery:rbac:dry": "node ./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register scripts/recover-rbac-production.ts --dry-run"
