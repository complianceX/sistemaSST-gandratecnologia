    "test:e2e:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "test:e2e:ci": "node scripts/run-e2e.cjs",
    "test:e2e:documental": "node --max-old-space-size=4096 scripts/run-jest.cjs --config ./test/jest-e2e.json --runInBand test/document-import-failures.e2e-spec.ts",
