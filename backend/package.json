  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "build:ci": "npm run build && npm run openapi:export && npm run openapi:export:governed",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint:types": "tsc --noEmit && eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "postinstall": "node scripts/ensure-puppeteer-browser.cjs",
    "start": "node scripts/start-dist.cjs dist/main.js",
    "start:local": "nest start",
    "prestart:dev": "node scripts/free-port.js",
    "start:dev": "nest start --watch",
    "prestart:debug": "node scripts/free-port.js",
    "start:debug": "nest start --debug --watch",
    "start:web": "node scripts/start-dist.cjs dist/main.js",
    "start:prod": "npm run start:web",
    "start:worker": "node scripts/start-dist.cjs dist/worker.js",
    "migration:run": "node scripts/run-migrations.js",
    "migration:run:targeted": "node scripts/run-targeted-migrations.js",
    "release:migrate": "npm run migration:run",
    "registry:reconcile": "node scripts/reconcile-document-registry.js --apply",
    "registry:reconcile:dry": "node scripts/reconcile-document-registry.js --dry-run",
    "dr:backup": "node -r ts-node/register/transpile-only scripts/dr-backup.ts",
    "dr:backup:dry-run": "node -r ts-node/register/transpile-only scripts/dr-backup.ts --dry-run",
    "dr:protect-storage": "node -r ts-node/register/transpile-only scripts/dr-protect-storage.ts",
    "dr:protect-storage:dry-run": "node -r ts-node/register/transpile-only scripts/dr-protect-storage.ts --dry-run",
    "dr:restore": "node -r ts-node/register/transpile-only scripts/dr-restore.ts",
    "dr:restore:dry-run": "node -r ts-node/register/transpile-only scripts/dr-restore.ts --dry-run",
    "dr:recover-environment": "node -r ts-node/register/transpile-only scripts/dr-recover-environment.ts",
    "dr:recover-environment:dry-run": "node -r ts-node/register/transpile-only scripts/dr-recover-environment.ts --dry-run",
    "dr:scan": "node -r ts-node/register/transpile-only scripts/dr-integrity-scan.ts",
    "dr:scan:dry-run": "node -r ts-node/register/transpile-only scripts/dr-integrity-scan.ts --dry-run",
    "rdo:preflight": "node scripts/rdo-pre-migration-check.js",
    "rdo:preflight:json": "node scripts/rdo-pre-migration-check.js --json",
    "rdo:perf:audit": "node scripts/rdo-performance-audit.js",
    "rdo:perf:audit:json": "node scripts/rdo-performance-audit.js --json",
    "storage:bucket-cutover": "node -r ts-node/register/transpile-only scripts/storage-bucket-cutover.ts --execute",
    "storage:bucket-cutover:dry-run": "node -r ts-node/register/transpile-only scripts/storage-bucket-cutover.ts --dry-run",
    "pdf:homologation": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.pdf-homologation.json scripts/generate-pdf-homologation.ts",
    "migration:revert": "typeorm migration:revert -d dist/data-source.js",
    "auth:sync:supabase": "node scripts/sync-users-to-supabase-auth.js",
    "auth:sync:supabase:apply": "node scripts/sync-users-to-supabase-auth.js --apply",
    "auth:cutover:readiness": "node scripts/audit-supabase-auth-cutover.js",
    "auth:cutover:readiness:json": "node scripts/audit-supabase-auth-cutover.js --json",
    "mail:runtime:audit": "node scripts/audit-mail-runtime.js",
    "mail:runtime:audit:json": "node scripts/audit-mail-runtime.js --json",
    "mail:runtime:prune-failed": "node scripts/audit-mail-runtime.js --prune-failed --min-age-minutes=1440",
    "privacy:cpf:verify": "node -r ts-node/register/transpile-only scripts/verify-cpf-encryption-key.ts",
    "privacy:cpf:backfill:dry": "node -r ts-node/register/transpile-only scripts/backfill-user-cpf-encryption.ts",
    "privacy:cpf:backfill:apply": "node -r ts-node/register/transpile-only scripts/backfill-user-cpf-encryption.ts --apply",
    "dds:themes:seed:dry": "node -r ts-node/register/transpile-only scripts/populate-dds-themes.ts --dry-run",
    "dds:themes:seed:apply": "node -r ts-node/register/transpile-only scripts/populate-dds-themes.ts --apply",
    "dds:themes:backfill:dry": "node -r ts-node/register/transpile-only scripts/backfill-dds-theme-library.ts --dry-run",
    "dds:themes:backfill:apply": "node -r ts-node/register/transpile-only scripts/backfill-dds-theme-library.ts --apply",
