    "loadtest:multi:baseline": "k6 run test/load/k6-load-test.js -e BASE_URL=http://localhost:3001 -e K6_SCENARIO_PROFILE=baseline",
    "loadtest:multi:stress": "k6 run test/load/k6-load-test.js -e BASE_URL=http://localhost:3001 -e K6_SCENARIO_PROFILE=stress",
