# ============================================
# 🛠️  CONFIGURAÇÃO DE DESENVOLVIMENTO
# ============================================

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# BANCO DE DADOS - POSTGRESQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123
DATABASE_NAME=sst_db

# SSL desabilitado em desenvolvimento
DATABASE_SSL=false
DATABASE_SSL_ALLOW_INSECURE=false

# ============================================
# REDIS - OPCIONAL EM DESENVOLVIMENTO
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_TLS=false

# ============================================
# JWT
# ============================================
JWT_SECRET=dev_secret_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
# Preferencial (novo): ACCESS_TOKEN_TTL; compatível com JWT_EXPIRES_IN (legado)
ACCESS_TOKEN_TTL=7d
# Preferencial (novo): REFRESH_TOKEN_TTL_DAYS; compatível com JWT_REFRESH_EXPIRATION (legado)
REFRESH_TOKEN_TTL_DAYS=30
JWT_REFRESH_EXPIRATION=30d
VALIDATION_TOKEN_SECRET=dev_validation_secret_change_in_production_min_32_chars
PUBLIC_VALIDATION_LEGACY_COMPAT=true
PUBLIC_VALIDATION_LOG_CONTRACT_USAGE=true
REFRESH_THROTTLE_LIMIT=20
REFRESH_THROTTLE_TTL=60000
REFRESH_CSRF_REPORT_ONLY=true
REFRESH_CSRF_ENFORCED=false
SECURITY_HARDENING_PHASE=phase0

# ============================================
# EMAIL - SMTP
# ============================================
MAIL_ENABLED=true
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_user
MAIL_PASS=your_smtp_password
MAIL_FROM_EMAIL=dev@localhost.com
MAIL_FROM_NAME=Dev System
MAIL_REPLY_TO_EMAIL=dev@localhost.com
MAIL_REPLY_TO_NAME=Dev System

# ============================================
# AWS S3 / CLOUDFLARE R2 (OPCIONAL)
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000

# ============================================
# OBSERVABILIDADE (OPCIONAL)
# ============================================
# JAEGER_AGENT_HOST=localhost
# JAEGER_AGENT_PORT=6831
# PROMETHEUS_PORT=9090

# ============================================
# AI - PROVIDERS (OPCIONAL)
# ============================================
FEATURE_AI_ENABLED=true
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-11-20
OPENAI_VISION_MODEL=gpt-4o-2024-11-20
OPENAI_FALLBACK_MODEL=gpt-4o-2024-11-20
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# AI_HISTORY_DEFAULT_DAYS=30
# AI_HISTORY_MAX_DAYS=90
# AI_HISTORY_MAX_LIMIT=100
